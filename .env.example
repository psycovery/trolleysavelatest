# ─────────────────────────────────────────
# TrolleySave — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────

# ── Supabase
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server only — never expose to client

# ── Stripe
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key              # Server only
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret        # From: stripe listen --forward-to localhost:3000/api/stripe/webhook

# ── App
NEXT_PUBLIC_APP_URL=http://localhost:3000              # Change to https://trolleysave.co.uk in production
NEXT_PUBLIC_APP_NAME=TrolleySave

# ── Stripe platform fee (1.5% = 150 basis points)
# Donation min fee in pence (£1.00 = 100)
STRIPE_PLATFORM_FEE_BPS=150
STRIPE_DONATION_MIN_FEE_PENCE=100
